{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
		"name": "Auth Controller (Mobile API)",
		"description": "Authentication endpoints for mobile applications including Login, Refresh Token, and Google Login.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Login",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"user@example.com\",\n    \"password\": \"yourpassword\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/v2/auth/login",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v2",
						"auth",
						"login"
					]
				},
				"description": "Authenticates user and returns Access and Refresh tokens."
			},
			"response": []
		},
		{
			"name": "Refresh Token",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"refresh_token\": \"your_refresh_token_here\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/v2/auth/refresh",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v2",
						"auth",
						"refresh"
					]
				},
				"description": "Obtain a new Access Token using a valid Refresh Token. Implements Rotation."
			},
			"response": []
		},
		{
			"name": "Google Login (Callback)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"id_token\": \"GOOGLE_ID_TOKEN_HERE\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/v2/auth/google-callback",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v2",
						"auth",
						"google-callback"
					]
				},
				"description": "Exchange a Google ID Token from Mobile SDK for local Access and Refresh tokens."
			},
			"response": []
		},
		{
			"name": "Register",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"username\": \"newuser\",\n    \"email\": \"newuser@example.com\",\n    \"password\": \"yourpassword\",\n    \"confirm_password\": \"yourpassword\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/v2/auth/register",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v2",
						"auth",
						"register"
					]
				},
				"description": "Registers a new user and returns success status."
			},
			"response": []
		},
		{
			"name": "Get Me (Check Token)",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{access_token}}"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/v2/me",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v2",
						"me"
					]
				},
				"description": "Returns the profile of the currently authenticated user. Used to verify Access Token."
			},
			"response": []
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "https://mangak.io.vn",
			"type": "string"
		}
	]
}
